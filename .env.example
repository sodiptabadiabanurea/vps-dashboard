# VPS Dashboard Configuration
# Copy to .env and customize

# Server
PORT=3000
HOST=127.0.0.1

# Authentication
DASHBOARD_USER=admin
DASHBOARD_PASS=your-strong-password-here

# Database
DB_PATH=/var/lib/vps-dashboard/dashboard.db

# Network interface to monitor
NET_IFACE=enp0s6

# Telegram alerts (optional)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# SSL domains to monitor (comma-separated)
SSL_DOMAINS=kakibaabu.duckdns.org,sahamradar.com

# Server name shown in alerts
SERVER_NAME=VPS

# File manager root directory
FM_ROOT=/root

# Backup directory
BACKUP_DIR=/var/lib/vps-dashboard/backups
